# Copy this file to ".env" (only needed for production builds).
#
# Base URL the MP3s are served from, no trailing slash.
#   - Local dev: leave BLANK. The app falls back to "/tracks", which the Vite
#     dev middleware serves from the local tracks/ folder (with range support).
#   - Production (Cloudflare Pages): set this to your public audio bucket URL,
#     e.g. a custom domain in front of an R2 bucket:
#         VITE_AUDIO_BASE=https://tunes.bradnamestunes.com
#     or the bucket's r2.dev public URL:
#         VITE_AUDIO_BASE=https://pub-xxxxxxxx.r2.dev
VITE_AUDIO_BASE=

# Which product this build is:
#   (unset / brad) -> Brad Names Tunes: full pool, Missed drill system.
#   ttt            -> Tap That Track: difficulty pop-up on load, no Missed.
# Both share the same VITE_AUDIO_BASE library. Set this to "ttt" only on the
# Tap That Track Cloudflare Pages project.
VITE_APP_VARIANT=
