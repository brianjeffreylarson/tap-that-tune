# Always revalidate the app shell so a new deploy is picked up immediately and
# the browser never serves a cached index.html that points at purged, hashed
# asset filenames (the cause of post-deploy white screens on mobile Safari).
/
  Cache-Control: no-cache, must-revalidate
/index.html
  Cache-Control: no-cache, must-revalidate

# Hashed build assets are content-addressed and safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
